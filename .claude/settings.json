{
  "permissions": {
    "deny": [
      "Read path:**/.env",
      "Read path:**/.env.*",
      "Read path:**/credentials.json",
      "Read path:**/secrets.yaml",
      "Read path:**/.pypirc",
      "Read path:**/.npmrc",
      "Edit path:**/.env",
      "Edit path:**/.env.*",
      "Edit path:**/credentials.json",
      "Edit path:**/secrets.yaml",
      "Edit path:**/.pypirc",
      "Edit path:**/.npmrc",
      "Write path:**/.env",
      "Write path:**/.env.*",
      "Write path:**/credentials.json",
      "Write path:**/secrets.yaml",
      "Write path:**/.pypirc",
      "Write path:**/.npmrc"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/cc_hook.py\" task-edit"
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/cc_hook.py\" state-edit"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bpsai-pair session check --quiet"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/cc_hook.py\" compact"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bpsai-pair session check --quiet"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/cc_hook.py\" teammate-idle"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/cc_hook.py\" task-completed"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bpsai-pair history-log --quiet"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bpsai-pair-statusline",
    "padding": 0
  }
}
